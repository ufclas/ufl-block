{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 2,
  "name": "create-block/single-post-intro",
  "version": "0.1.0",
  "title": "Post Intro Block",
  "category": "theme",
  "icon": "index-card",
  "description": "",
  "supports": {
    "html": false
  },
  "attributes": {
    "text": {
      "type": "string",
      "default": ""
    },
    "sectionSubtitle": {
      "type": "string",
      "default": ""
    },
    "showFacebook": {
      "type": "boolean",
      "default": true
    },
    "showTwitter": {
      "type": "boolean",
      "default": true
    },
    "showEmail": {
      "type": "boolean",
      "default": true
    },
    "showLinkedin": {
      "type": "boolean",
      "default": true
    },
    "showBluesky": {
      "type": "boolean",
      "default": true
    }
  },
  "textdomain": "single-post-intro",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css"
}